GEMINI_API_KEY=YOUR_API_KEY
GEMINI_MODEL=gemini-3.5-flash
YOLO_WORLD_WEIGHTS=yolov8x-worldv2.pt
SAM2_CHECKPOINT=/absolute/path/to/sam2.1_hiera_tiny.pt
SAM2_MODEL_CFG=configs/sam2.1/sam2.1_hiera_t.yaml

SYSNAV_SCENE_GRAPH_EXPORT=1
SYSNAV_SCENE_GRAPH_SAVE_IMAGES=1
SYSNAV_SCENE_GRAPH_USE_GEMINI=1
SYSNAV_SINGLE_ROOM_ID=0
SYSNAV_SINGLE_ROOM_NAME=Room_0
SYSNAV_RELATION_MIN_CONFIDENCE=0.55

SYSNAV_VIEWPOINT_COVERAGE_DISTANCE_M=4.0
SYSNAV_VIEWPOINT_COVERAGE_VOXEL_SIZE_M=0.40
SYSNAV_VIEWPOINT_NOVEL_VOXEL_THRESHOLD=120
SYSNAV_VIEWPOINT_COVERAGE_MAX_RAYS=1600
SYSNAV_VIEWPOINT_COVERAGE_MIN_RANGE_M=0.20
SYSNAV_VIEWPOINT_COVERAGE_Z_MIN_M=-0.60
SYSNAV_VIEWPOINT_COVERAGE_Z_MAX_M=2.50
