FROM zhangjicmu/ubuntu24_ros:ai_module

# apt/pip 설치를 위해 잠시 root 로 전환
USER root

# 베이스 이미지에 pip 이 없으므로 apt 로 먼저 설치
RUN apt-get update && \
    apt-get install -y \
        python3-pip \
        wget \
        ros-jazzy-pcl-ros \
        libpcl-dev \
        nlohmann-json3-dev \
        libgoogle-glog-dev \
        ros-jazzy-backward-ros && \
    rm -rf /var/lib/apt/lists/*

# 파이썬 인식/추론 라이브러리
#   - GroundingDINO(검출) + Qwen2-VL(선택) 둘 다 transformers 로 로드
#   - qwen-vl-utils: Qwen 비전 입력 헬퍼
#   - accelerate: device_map 로딩
RUN python3 -m pip install --no-cache-dir --break-system-packages \
    "torch" "torchvision" \
    "transformers>=4.49" \
    "qwen-vl-utils" \
    "accelerate" \
    "pillow" "numpy"

# SysNav semantic mapping, VLM and TensorRT dependencies. Ubuntu installs
# psutil through apt without pip RECORD metadata, so install its wheel first.
COPY src/SysNav/requirement.txt /tmp/sysnav-requirement.txt
RUN python3 -m pip install --no-cache-dir --break-system-packages \
        --ignore-installed "psutil==7.2.2" && \
    python3 -m pip install --no-cache-dir --break-system-packages \
        -r /tmp/sysnav-requirement.txt && \
    python3 -m pip uninstall --break-system-packages -y clip && \
    python3 -m pip install --no-cache-dir --break-system-packages \
        git+https://github.com/ultralytics/CLIP.git && \
    python3 -m pip install --no-cache-dir --break-system-packages \
        --ignore-installed "numpy==1.26.4" && \
    python3 -m pip install --no-cache-dir --break-system-packages \
        "numpy<2" "onnxruntime-gpu" "onnxslim>=0.1.82" \
        "nvidia-modelopt[onnx]>=0.44" && \
    python3 -m pip install --no-cache-dir --break-system-packages \
        "setuptools==79.0.1"

COPY src/SysNav/src/semantic_mapping/semantic_mapping/external/sam2 /tmp/sam2
RUN python3 -m pip install --no-cache-dir --break-system-packages -e /tmp/sam2

# 모델 가중치 빌드 시점에 미리 받기 (test-time 네트워크 불필요)
#  1) GroundingDINO-tiny  2) Qwen2-VL-2B-Instruct
# Qwen2.5-VL-3B(~6.3GB)는 GroundingDINO+SAM이랑 8GB GPU에 같이 못 들어가서(OOM)
# Qwen2-VL-2B(~4GB)로 낮춤 (2026-07-09).
RUN python3 -c "\
from transformers import AutoProcessor, AutoModelForZeroShotObjectDetection; \
m='IDEA-Research/grounding-dino-tiny'; \
AutoProcessor.from_pretrained(m); \
AutoModelForZeroShotObjectDetection.from_pretrained(m); \
print('GroundingDINO cached.')" || echo "WARN: grounding-dino pre-download skipped"

RUN python3 -c "\
from transformers import AutoProcessor, Qwen2VLForConditionalGeneration; \
m='Qwen/Qwen2-VL-2B-Instruct'; \
AutoProcessor.from_pretrained(m); \
Qwen2VLForConditionalGeneration.from_pretrained(m, torch_dtype='auto'); \
print('Qwen2-VL cached.')" || echo "WARN: qwen pre-download skipped"

# 3) SAM (box-prompted segmentation, bbox 안 배경 point 오염 줄이는 데 사용)
RUN python3 -c "\
from transformers import SamModel, SamProcessor; \
m='facebook/sam-vit-base'; \
SamProcessor.from_pretrained(m); \
SamModel.from_pretrained(m); \
print('SAM cached.')" || echo "WARN: SAM pre-download skipped"

# tmah_vlm 소스 복사
COPY src/tmah_vlm /home/docker/ai_module/src/tmah_vlm
COPY src/SysNav /home/docker/ai_module/src/SysNav
COPY src/sysnav_challenge /home/docker/ai_module/src/sysnav_challenge
RUN bash /home/docker/ai_module/src/sysnav_challenge/scripts/apply_sysnav_patch.sh

# tmah_vlm 패키지만 빌드
WORKDIR /home/docker/ai_module
RUN /bin/bash -c "\
    source /opt/ros/jazzy/setup.bash && \
    colcon build --symlink-install --packages-select tmah_vlm"

# Keep the heavy SysNav C++ build separate from the legacy package so the
# mounted development workspace cannot hit ownership conflicts.
RUN /bin/bash -c "\
    source /opt/ros/jazzy/setup.bash && \
    colcon --log-base log_sysnav build --symlink-install \
      --build-base build_sysnav \
      --install-base install_sysnav \
      --cmake-args -DCMAKE_BUILD_TYPE=Release \
      --base-paths src/SysNav/src src/sysnav_challenge \
      --packages-select tare_planner semantic_mapping vlm_node sysnav_challenge"

RUN echo "source /home/docker/ai_module/install/setup.bash" >> /home/docker/.bashrc
RUN echo "source /home/docker/ai_module/install_sysnav/setup.bash" >> /home/docker/.bashrc

# 원래 유저로 복귀
USER docker
